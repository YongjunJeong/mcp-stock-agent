# ─────────────────────────────────────────────────────────────────
# .env.example — 설정 템플릿
# 사용법: cp .env.example .env  →  .env 파일에 실제 값 입력
# .env 파일은 절대 Git에 커밋하지 마세요!
# ─────────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────────
# 발급: https://aistudio.google.com/  (무료 tier 사용 가능)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Slack ─────────────────────────────────────────────────────────
# Bot Token: https://api.slack.com/apps → OAuth & Permissions
# xoxb- 로 시작하는 토큰
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App Token: 앱 설정 → Basic Information → App-Level Tokens
# xapp- 로 시작하는 토큰 (Socket Mode용)
SLACK_APP_TOKEN=xapp-your-app-token-here

# 알림 채널 ID (채널명이 아닌 ID, C로 시작)
# 채널 우클릭 → "채널 ID 복사"
SLACK_CHANNEL_ID=C000000000

# ── 분석 설정 ──────────────────────────────────────────────────────
# 매수 신호 임계값 (Final Score ≥ 이 값 → Slack 알림)
SIGNAL_THRESHOLD_STRONG=70

# 기본 조회 기간 (1mo / 3mo / 6mo / 1y)
DEFAULT_PERIOD=6mo

# ── 스케줄러 워치리스트 (쉼표 구분 종목코드) ──────────────────────
# 한국 주식 6자리 코드
WATCHLIST_KR=005930,000660,035420
